[color]
    ui = true
[core]
    quotepath = false
[init]
    defaultbranch = main
[merge]
	ff = false
[pull]
    ff = only
    rebase = false
[include]
    path = user.gitconfig
[filter "lfs"]
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
